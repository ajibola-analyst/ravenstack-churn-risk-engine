      <aliases enabled='yes' />
      <column caption='Churned Account Flag' datatype='integer' name='[Calculation_0576156944343040]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [account_id] : MAX(IF [target_churn_flag] = 1 AND [Calculation_1381197722521067526] = TRUE THEN 1 ELSE 0 END) }' />
      </column>
      <column caption='Churned ARR Fixed' datatype='real' name='[Calculation_0576156944842753]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_0576156944343040] = 1 THEN { FIXED [account_id] : MAX([active_mrr_run_rate]) } * 12 ELSE 0 END' />
      </column>
      <column caption='FIXED LOD' datatype='real' name='[Calculation_1155873788702720]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [account_id] : MAX(IF [target_churn_flag] = 1 AND [Calculation_1381197722521067526] = TRUE THEN [active_mrr_run_rate] * 12 ELSE 0 END) }' />
      </column>
      <column caption='First Month MRR' datatype='real' name='[Calculation_1155873795956737]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : SUM(&#13;&#10;    IF [Calculation_762515723369472001] = 1 &#13;&#10;    AND [Calculation_762515723369340928] = { FIXED : MIN([Calculation_762515723369340928]) } &#13;&#10;    THEN [active_mrr_run_rate] &#13;&#10;    ELSE 0 END&#13;&#10;) }' />
      </column>
      <column caption='f lastest mrr' datatype='real' name='[Calculation_1155873796112386]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : SUM(&#13;&#10;    IF [Calculation_762515723372249097] = True &#13;&#10;    THEN [active_mrr_run_rate] &#13;&#10;    ELSE 0 END&#13;&#10;) }' />
      </column>
      <column caption='f MRR Growth Multiple' datatype='real' name='[Calculation_1155873796395011]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1155873796112386] / [Calculation_1155873795956737]' />
      </column>
      <column caption='Churned ARR 90D' datatype='real' name='[Calculation_1210060937016385536]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [target_churn_flag] = 1 AND [Calculation_1381197722521067526] = TRUE THEN [active_mrr_run_rate] * 12 ELSE 0 END' />
      </column>
      <column caption='Velocity Color' datatype='string' name='[Calculation_1210060937016537089]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([net_mrr_delta]) &gt;= 0 THEN &quot;Positive&quot; ELSE &quot;Negative&quot; END' />
      </column>
      <column caption='Recognized Churned ARR' datatype='real' name='[Calculation_1381197722483597316]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [target_churn_flag] = 1 THEN ([active_mrr_run_rate] * 12) ELSE 0 END' />
      </column>
      <column caption='Is Trailing 90 Days' datatype='boolean' name='[Calculation_1381197722521067526]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[observation_date] &gt;= DATEADD(&apos;day&apos;, -90, { FIXED : MAX([observation_date]) })' />
      </column>
      <column caption='Executive Observation Month' datatype='datetime' name='[Calculation_762515723369340928]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [observation_date])' />
      </column>
      <column caption='End of Month Flag' datatype='integer' name='[Calculation_762515723369472001]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF [observation_date] = { FIXED [Calculation_762515723369340928] : MAX([observation_date]) } THEN 1 ELSE 0 END' />
      </column>
      <column caption='Snapshot MRR' datatype='real' name='[Calculation_762515723369721858]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_762515723369472001] = 1 THEN [active_mrr_run_rate] ELSE 0 END' />
      </column>
      <column caption='ARR Run Rate' datatype='real' name='[Calculation_762515723370467331]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_762515723369721858] * 12' />
      </column>
      <column caption='At-Risk ARR' datatype='real' name='[Calculation_762515723370561540]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_762515723369472001] = 1 AND ([daily_friction_events] &gt; 5 OR [avg_csat_score] &lt; 3) THEN ([active_mrr_run_rate] * 12) ELSE 0 END' />
      </column>
      <column caption='Cohort Month' datatype='datetime' default-format='*mmm yyyy' name='[Calculation_762515723370688517]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [account_id] : MIN(DATETRUNC(&apos;month&apos;, [observation_date])) }' />
      </column>
      <column caption='Months Since Acquisition' datatype='integer' name='[Calculation_762515723370823686]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEDIFF(&apos;month&apos;, [Calculation_762515723370688517], [Calculation_762515723369340928])' />
      </column>
      <column caption='Cohort Starting Size' datatype='integer' name='[Calculation_762515723370962951]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_762515723370688517] : COUNTD([account_id]) }' />
      </column>
      <column caption='Retention %' datatype='real' name='[Calculation_762515723371073544]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([account_id]) / MIN([Calculation_762515723370962951])' />
      </column>
      <column caption='Is Latest Date' datatype='boolean' name='[Calculation_762515723372249097]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[observation_date] = { FIXED : MAX([observation_date]) }' />
      </column>
      <column caption='ARPA' datatype='real' name='[Calculation_762515723379900426]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_762515723388444686] / COUNTD(IF [active_mrr_run_rate] &gt; 0 THEN [account_id] END)' />
      </column>
      <column caption='Is Trailing 30 Days' datatype='boolean' name='[Calculation_762515723386724365]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[observation_date] &gt;= DATEADD(&apos;day&apos;, -30, { FIXED : MAX([observation_date]) })' />
      </column>
      <column caption='Current ARR' datatype='real' name='[Calculation_762515723388444686]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([active_mrr_run_rate]) * 12' />
      </column>
      <column caption='Daily App Mins' datatype='real' name='[Calculation_762515723390296079]' role='measure' type='quantitative'>
