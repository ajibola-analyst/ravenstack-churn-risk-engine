    <worksheet name='MRR Growth Trajectory'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#1e293b' fontname='Tableau Bold' fontsize='10'>Revenue has grown 144× since launch</run>
            <run>Æ&#10;</run>
            <run fontcolor='#94a3b8' fontname='Tableau Bold' fontsize='8'>Monthly Recurring Revenue at end of each month · Jan 2023 – Nov 2024 · from $4,513 to $573,187</run>
          </formatted-text>
        </title>
