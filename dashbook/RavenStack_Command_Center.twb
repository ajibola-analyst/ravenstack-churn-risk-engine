              <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [observation_date])' />
            </column>
            <column aggregation='Sum' caption='End of Month Flag' datatype='integer' name='[Calculation_762515723369472001]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='IF [observation_date] = { FIXED [Calculation_762515723369340928] : MAX([observation_date]) } THEN 1 ELSE 0 END' />
            </column>
            <column caption='Cohort Month' datatype='datetime' default-format='*mmm yyyy' name='[Calculation_762515723370688517]' role='dimension' type='ordinal'>
